---
//src/layouts/BaseLayout.astro
import "../styles/global.css";
import { withBase } from "../lib/paths";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Curso de Java",
  description = "Curso de Java para personas que ya programan y quieren aprender Java en serio.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={withBase("/favicon-j-similar.svg")}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href={withBase("/favicon-j-similar-32.png")}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="256x256"
      href={withBase("/favicon-j-similar-256.png")}
    />

    <style is:inline>
      :root {
        --bg: #0b1020;
        --bg-soft: #111933;
        --panel: #121c36;
        --panel-2: #182448;
        --text: #eef2ff;
        --muted: #a8b3cf;
        --line: rgba(255, 255, 255, 0.1);
        --accent: #6ea8fe;
        --accent-2: #8b5cf6;
        --code-bg: #0a1226;
        --success: #2dd4bf;
        --shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
        --radius: 18px;
        --radius-sm: 12px;
        --content-width: 1120px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 96px;
        background-color: var(--bg);
        min-height: 100%;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.65;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      code,
      pre {
        font-family:
          "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
      }

      main {
        min-height: 60vh;
      }

      .container {
        width: min(var(--content-width), calc(100% - 2rem));
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(14px);
        background: rgba(9, 16, 31, 0.7);
        border-bottom: 1px solid var(--line);
      }

      .site-header__inner,
      .site-footer__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 0;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .brand__mark {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        box-shadow: var(--shadow);
        font-weight: 800;
        color: white;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .nav a {
        color: var(--muted);
        transition: color 0.2s ease;
      }

      .nav a:hover,
      .nav a:focus-visible {
        color: var(--text);
      }

      .site-footer {
        margin-top: 3rem;
        border-top: 1px solid var(--line);
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.02) 0%,
          rgba(255, 255, 255, 0.01) 100%
        );
      }

      .site-footer__inner {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) auto;
        align-items: center;
        gap: 1.25rem;
        padding: 1.5rem 0 1.75rem;
      }

      .footer-info {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }

      .footer-title {
        margin: 0;
        color: var(--text);
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.35;
      }

      .footer-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        align-items: center;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .footer-meta strong {
        color: var(--text);
      }

      .footer-separator {
        color: rgba(255, 255, 255, 0.24);
      }

      .footer-note {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.65;
      }

      .footer-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
      }

      .footer-repo {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text);
        font-weight: 600;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          background-color 0.2s ease;
      }

      .footer-repo:hover,
      .footer-repo:focus-visible {
        transform: translateY(-1px);
        border-color: rgba(110, 168, 254, 0.45);
        background: rgba(110, 168, 254, 0.08);
      }

      .footer-repo svg {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        margin: 0 0 1rem;
      }

      h1 {
        font-size: 2.6rem;
        letter-spacing: -0.04em;
      }

      h2 {
        font-size: 1.8rem;
        letter-spacing: -0.03em;
      }

      h3 {
        font-size: 1.2rem;
      }

      p {
        margin: 0 0 1rem;
        color: var(--muted);
      }

      .muted {
        color: var(--muted);
      }

      .hero__lead {
        font-size: 1.1rem;
        max-width: 60ch;
      }

      .card,
      .topic-summary {
        background-color: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        font-size: 0.86rem;
        color: var(--text);
      }

      .topic-page {
        padding: 2.8rem 0 4rem;
      }

      .topic-page__header {
        margin-bottom: 1.4rem;
      }

      .topic-page__header h1 {
        font-size: 2.4rem;
      }

      .breadcrumbs {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        color: var(--muted);
        font-size: 0.95rem;
        margin-bottom: 1rem;
      }

      .topic-page__grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 1.5rem;
        align-items: start;
      }

      .content-card {
        padding: 1.5rem;
      }

      .content-card :where(h1, h2, h3, h4, h5, h6) {
        scroll-margin-top: 96px;
      }

      .content-card :where(h2, h3) {
        margin-top: 2rem;
      }

      .content-card :where(h1) {
        font-size: 1.8rem;
      }

      .content-card h2 {
        font-size: 1.4rem;
      }

      .content-card :where(ul, ol) {
        color: var(--muted);
        padding-left: 1.25rem;
      }

      .content-card :where(li + li) {
        margin-top: 0.5rem;
      }

      .content-card pre {
        background: var(--code-bg);
        border: 1px solid var(--line);
        padding: 1rem;
        border-radius: var(--radius-sm);
        overflow-x: auto;
      }

      .content-card code:not(pre code) {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 0.15rem 0.4rem;
      }

      .topic-summary {
        position: sticky;
        top: 88px;
        padding: 1.1rem;
        max-height: calc(100vh - 94px);
        overflow-y: auto;
      }

      .topic-summary h3 {
        margin-bottom: 0.75rem;
      }

      .topic-summary p {
        font-size: 0.96rem;
      }

      .topic-summary__list {
        display: grid;
        gap: 0.65rem;
        margin-top: 1rem;
      }

      .topic-summary__list a {
        color: var(--muted);
      }

      .topic-summary__list a:hover,
      .topic-summary__list a:focus-visible {
        color: var(--text);
      }

      .topic-nav {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        margin-top: 2rem;
        flex-wrap: wrap;
      }

      .topic-nav a {
        flex: 1 1 220px;
        padding: 1rem;
        border-radius: var(--radius-sm);
        border: 1px solid var(--line);
        background-color: rgba(255, 255, 255, 0.03);
      }

      .autotestAnchor {
        font-size: 1.4rem;
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
      }

      @media (min-width: 921px) {
        body {
          display: flex;
          flex-direction: column;
        }

        main {
          flex: 1 0 auto;
        }

        .site-footer {
          margin-top: auto;
          flex-shrink: 0;
        }
      }

      @media (max-width: 920px) {
        .topic-page__grid {
          grid-template-columns: 1fr;
        }

        .topic-summary {
          position: static;
          max-height: none;
        }

        h1 {
          font-size: 2.4rem;
        }

        h2 {
          font-size: 1.5rem;
        }
      }

      @media (max-width: 820px) {
        .site-footer__inner {
          grid-template-columns: 1fr;
          justify-items: center;
          text-align: center;
        }

        .footer-info {
          align-items: center;
        }

        .footer-meta {
          justify-content: center;
        }

        .footer-actions {
          justify-content: center;
        }

        .footer-separator {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href={withBase("/")} class="brand">
          <span class="brand__mark">J</span>
          <span><span style="color: red;">J</span>ava desde cero</span>
        </a>

        <nav class="nav" aria-label="Principal">
          <a href={withBase("/")}>Inicio</a>
          <a href={withBase("/cursos")}>Otros cursos</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <div class="footer-info">
          <p class="footer-title">Gabriel Survila</p>

          <div class="footer-meta">
            <span>Software libre bajo <strong>licencia MIT</strong></span>
            <span class="footer-separator">•</span>
            <span>
              Hecho con ayuda de ChatGPT <strong>GPT-5.4 Thinking</strong>
            </span>
          </div>

          <p class="footer-note">
            Proyecto público, editable y pensado como material de apoyo para
            estudiar Java.
          </p>
        </div>

        <div class="footer-actions">
          <a
            class="footer-repo"
            href="https://github.com/SurvilaDeveloper/curso-java-y-backend"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Ver repositorio en GitHub"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.426 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.699-2.782.605-3.369-1.343-3.369-1.343-.455-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.004.071 1.532 1.033 1.532 1.033.892 1.53 2.341 1.088 2.91.832.091-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.027A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.297 2.748-1.027 2.748-1.027.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.481A10.019 10.019 0 0 0 22 12.017C22 6.484 17.523 2 12 2Z"
              ></path>
            </svg>
            <span>Ver repositorio</span>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
