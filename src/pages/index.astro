---
//src/pages/index.astro
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseContentSwitcher from "../components/CourseContentSwitcher.astro";
import AboutModal from "../components/AboutModal.astro";
import TechLogo from "../components/TechLogo.astro";
import { withBase } from "../lib/paths";

type JavaTema = CollectionEntry<"javaTemas">;

const temas = (
  await getCollection("javaTemas", (tema: JavaTema) => !tema.data.draft)
).sort((a, b) => a.data.order - b.data.order);

const modulesMap = new Map<string, JavaTema[]>();

for (const tema of temas) {
  const current = modulesMap.get(tema.data.module) ?? [];
  current.push(tema);
  modulesMap.set(tema.data.module, current);
}

const modules = Array.from(modulesMap.entries());
---

<BaseLayout title="Curso de Java con Astro">
  <AboutModal />

  <section class="hero">
    <div class="container hero__grid">
      <div>
        <div style="display:flex; flex-direction:row; align-items: center;">
          <TechLogo name="java" label={false} />
          <h1>Curso de <span style="color: red;">J</span>ava y backend</h1>
        </div>

        <p class="hero__lead">
          Curso principal del sitio. Los cursos complementarios están
          disponibles en una sección aparte.
        </p>

        <div class="hero-actions">
          <button id="aboutModalButton" class="hero-link">
            Acerca de este sitio
          </button>

          <a class="hero-link" href={withBase("/cursos")}> Ver otros cursos </a>
          <a class="hero-link" href={withBase("/articulos")}> Ver artículos </a>
        </div>
      </div>
    </div>
  </section>

  <CourseContentSwitcher temas={temas} modules={modules} basePath="/temas" />

  <script>
    const aboutModalButton = document.getElementById("aboutModalButton");
    const aboutModalMain = document.getElementById("aboutModalMain");

    aboutModalButton?.addEventListener("click", () => {
      window.dispatchEvent(new Event("about-modal:open"));

      if (aboutModalMain && aboutModalMain.style.display !== "flex") {
        aboutModalMain.style.display = "flex";
      }
    });
  </script>
</BaseLayout>
