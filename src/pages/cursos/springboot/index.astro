---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CourseContentSwitcher from "../../../components/CourseContentSwitcher.astro";
import TechLogo from "../../../components/TechLogo.astro";

const temas = (
    await getCollection("springbootTemas", ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);

const modulesMap = new Map();
for (const tema of temas) {
    const current = modulesMap.get(tema.data.module) ?? [];
    current.push(tema);
    modulesMap.set(tema.data.module, current);
}

const modules = Array.from(modulesMap.entries());
---

<BaseLayout title="Curso de Spring Boot">
    <!-- HERO igual que antes -->
    <section class="hero">
        <div class="container hero__grid">
            <div>
                <div
                    style="display:flex; flex-direction:row; align-items: center;"
                >
                    <TechLogo name="spring" label={false} />
                    <h1>Curso de Spring Boot</h1>
                </div>

                <p class="hero__lead">
                    Un recorrido ordenado para aprender Spring Boot desde
                    fundamentos hasta backend real.
                </p>
                <div class="cta-row">
                    <a class="button-secondary" href="/">Ver Java</a>
                </div>
            </div>
        </div>
    </section>

    <CourseContentSwitcher
        temas={temas}
        modules={modules}
        basePath="/cursos/springboot"
    />
</BaseLayout>
