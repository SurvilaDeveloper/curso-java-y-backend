---
//src/components/TechLogo.astro
import { withBase } from "../lib/paths";

interface Props {
    name:
        | "java"
        | "spring"
        | "maven"
        | "docker"
        | "flyway"
        | "attack"
        | "security"
        | "microservicios";
    size?: number;
    label?: boolean;
}

const { name, size = 48, label = true } = Astro.props as Props;

const logos = {
    java: {
        label: "Java",
        src: withBase("/java-original.svg"),
    },
    spring: {
        label: "Spring Boot",
        src: withBase("/spring-original.svg"),
    },
    maven: {
        label: "Maven",
        src: withBase("/maven-original.svg"),
    },
    docker: {
        label: "Docker",
        src: withBase("/docker-original.svg"),
    },
    flyway: {
        label: "Flyway",
        src: withBase("/flyway.svg"),
    },
    attack: {
        label: "Ciber attack",
        src: withBase("/attack.svg"),
    },
    security: {
        label: "Security backend",
        src: withBase("/backend-security-logo.svg"),
    },
    microservicios: {
        label: "Microservicios",
        src: withBase("/logo-microservicios.svg"),
    },
};

const tech = logos[name];
---

<div class="tech-logo">
    <div class="icon">
        <img src={tech.src} alt={tech.label} width={size} height={size} />
    </div>

    {label && <span>{tech.label}</span>}
</div>

<style>
    .tech-logo {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;

        padding: 0.5rem 0.75rem;
        border-radius: 0.75rem;

        border: 1px solid hsl(var(--border));
        background-color: hsl(var(--card));

        transition: all 0.2s ease;
    }

    .tech-logo:hover {
        background-color: hsl(var(--accent));
        transform: translateY(-2px);
    }

    .icon {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    span {
        font-size: 0.9rem;
        font-weight: 500;
        color: hsl(var(--foreground));
    }
</style>
